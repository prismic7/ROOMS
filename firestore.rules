rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers (JWT-only checks — no Firestore reads) ────
    function isSignedIn() {
      return request.auth != null;
    }
    function isNEUEmail() {
      return isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email.matches('.*@neu\\.edu\\.ph');
    }
    // Role is stored as a custom claim OR we fall back to a whitelist read.
    // To keep rules fast we use a single get() only where role matters.
    function getRole() {
      return get(/databases/$(database)/documents/whitelist/$(request.auth.token.email)).data.role;
    }
    function isWhitelisted() {
      return isNEUEmail()
          && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email));
    }
    function isAdmin() {
      return isWhitelisted() && getRole() == 'admin';
    }

    // ── whitelist ─────────────────────────────────────────
    match /whitelist/{email} {
      allow read:   if isWhitelisted();
      allow write:  if isAdmin();
      allow delete: if isAdmin();
      // professors can update only their own doc, only safe fields
      allow update: if isWhitelisted()
                    && request.auth.token.email == email
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['lastSeen','displayName']);
    }

    // ── rooms ─────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:  if isWhitelisted();
      allow write: if isAdmin();
    }

    // ── usage_logs ────────────────────────────────────────
    match /usage_logs/{logId} {
      allow create: if isWhitelisted()
                    && request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin()
                    || (isWhitelisted()
                        && resource.data.email == request.auth.token.email
                        && request.resource.data.email  == resource.data.email
                        && request.resource.data.roomId == resource.data.roomId);
      allow read:   if isAdmin()
                    || (isWhitelisted()
                        && resource.data.email == request.auth.token.email)
                    || (isWhitelisted()
                        && resource.data.status == 'active');
      allow delete: if isAdmin();
    }

    // ── audit_trail ───────────────────────────────────────
    // Write: any signed-in NEU email — no extra Firestore read needed.
    //        actorEmail must equal the authenticated user's email.
    // Read:  admin only (uses isAdmin which does a whitelist get — acceptable
    //        because reads are infrequent and initiated by admins deliberately).
    // Immutable: no update or delete ever.
    match /audit_trail/{entryId} {
      allow create: if isNEUEmail()
                    && request.resource.data.actorEmail == request.auth.token.email
                    && request.resource.data.keys().hasAll(['actorEmail','actorName','actorRole','action','details','timestamp']);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
    // ── notifications ─────────────────────────────────────
    match /notifications/{notifId} {
      allow create: if isAdmin();
      allow read:   if isWhitelisted()
                    && resource.data.toEmail == request.auth.token.email;
      allow update: if isWhitelisted()
                    && resource.data.toEmail == request.auth.token.email
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }
  }
}
